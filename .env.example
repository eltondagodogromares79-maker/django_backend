# Database switching
# Set to local for your machine database, or remote for the hosted Postgres URL below.
DATABASE_TARGET=local
DB_ENGINE=django.db.backends.postgresql
DB_NAME=capstone_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
REMOTE_DATABASE_URL=
DB_SSL_REQUIRE=true
DB_CONN_MAX_AGE=600

