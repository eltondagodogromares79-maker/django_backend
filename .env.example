# ─────────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────────

# Generate a secret key at: https://djecrety.ir
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here

# Set to false in production
DEBUG=true

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# Database
# Set DATABASE_TARGET=local to use individual DB_ vars below
# Set DATABASE_TARGET=remote to use REMOTE_DATABASE_URL
# ─────────────────────────────────────────────
DATABASE_TARGET=local

# Local PostgreSQL credentials
DB_ENGINE=django.db.backends.postgresql
DB_NAME=capstone_db
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_HOST=localhost
DB_PORT=5432

# Remote PostgreSQL (Render, Supabase, etc.)
# Example: postgres://user:password@host:5432/dbname
REMOTE_DATABASE_URL=postgres://your_db_user:your_db_password@your_db_host:5432/your_db_name

DB_SSL_REQUIRE=true
DB_CONN_MAX_AGE=600

# ─────────────────────────────────────────────
# Frontend URLs (CORS + CSRF)
# Comma-separated list of allowed frontend origins
# ─────────────────────────────────────────────
FRONTEND_URLS=http://localhost:3000,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Extra CORS origins (e.g. chat server, mobile app)
# ws:// and wss:// are not valid CORS origins — use the http/https equivalent
EXTRA_CORS_URLS=http://localhost:8080,https://your-chat-server.onrender.com

# ─────────────────────────────────────────────
# Cloudinary (media/file storage)
# Get credentials at: https://cloudinary.com → Dashboard
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─────────────────────────────────────────────
# Jitsi (online classes)
# ─────────────────────────────────────────────
JITSI_BASE_URL=https://meet.jit.si
ATTENDANCE_LATE_AFTER_MINUTES=10

# ─────────────────────────────────────────────
# Chat server
# Set CHAT_SERVER_TARGET=local or remote
# ─────────────────────────────────────────────
CHAT_SERVER_TARGET=local
CHAT_SERVER_HTTP_LOCAL_URL=http://127.0.0.1:8080
CHAT_SERVER_HTTP_REMOTE_URL=https://your-chat-server.onrender.com
CHAT_SERVER_WS_LOCAL_URL=ws://127.0.0.1:8080/ws/chat/
CHAT_SERVER_WS_REMOTE_URL=wss://your-chat-server.onrender.com/ws/chat/
CHAT_SERVER_TOKEN=your-chat-server-secret-token

# ─────────────────────────────────────────────
# AI Grading
# Get Gemini API key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# OpenAI (optional alternative)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_BASE=https://api.openai.com/v1

# ─────────────────────────────────────────────
# Email (SMTP)
# For Gmail: enable 2FA and use an App Password
# ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=SCSIT NEXUS <no-reply@yourdomain.com>

# ─────────────────────────────────────────────
# PDF generation (optional)
# ─────────────────────────────────────────────
PDF_LOGO_PATH=
PDF_HEADER_TEXT=Learning Materials Pack
PDF_FOOTER_TEXT=Generated by AI learning materials assistant
PDF_FILENAME_TEMPLATE={subject}-{title}-{date}.pdf

# ─────────────────────────────────────────────
# Security (set these to true in production)
# ─────────────────────────────────────────────
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
